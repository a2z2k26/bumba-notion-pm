# Bumba Notion PM — environment variables
# Copy this file to `.env` and fill in your values. NEVER commit `.env`.

# ─────────────────────────────────────────────────────────────
# Required
# ─────────────────────────────────────────────────────────────

# Notion integration token. Get one at https://www.notion.so/my-integrations
# Format: starts with `secret_` or `ntn_`
NOTION_API_KEY=

# Parent page that the integration is shared with. Bumba creates child pages
# and databases under this page.
# How to get: open the page in Notion → "..." menu → Copy link → grab the
# 32-char hex ID from the URL.
NOTION_PARENT_PAGE_ID=

# ─────────────────────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────────────────────

# Default database ID (used when a command doesn't specify one)
# NOTION_DATABASE_ID=

# Workspace ID (rarely needed; integrations are workspace-scoped via the token)
# NOTION_WORKSPACE_ID=

# MCP bridge — point at a running Notion MCP server to route calls through it
# NOTION_MCP_SERVER_URL=http://localhost:3000

# Notion API version. Default is the latest the connector knows about.
# NOTION_API_VERSION=2022-06-28

# ─────────────────────────────────────────────────────────────
# GitHub sync (only needed if using GitHubIssueBridge)
# ─────────────────────────────────────────────────────────────

# Personal access token with `repo` scope
# GITHUB_TOKEN=

# Notion database ID where issues sync to
# NOTION_TASKS_DATABASE_ID=

# Repository in `owner/repo` form
# GITHUB_REPO=

# ─────────────────────────────────────────────────────────────
# Debug
# ─────────────────────────────────────────────────────────────

# Set to `true` to enable verbose logging
# NOTION_DEBUG=false
